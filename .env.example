# ================================================================
# Thai App Market — Environment Variables
# ================================================================
# คัดลอกไฟล์นี้เป็น .env (สำหรับ local dev) หรือ
# ไปตั้งค่าใน Vercel Dashboard → Project → Settings → Environment Variables
# ================================================================

# Supabase Project URL
# หาได้จาก: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon / Public Key
# หาได้จาก: Supabase Dashboard → Settings → API → anon public
SUPABASE_ANON_KEY=your-anon-key-here
